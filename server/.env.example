# ──────────────────────────────────────────────────────────────
# Spark server environment. Copy to `.env` on the VPS and fill in.
#    cp .env.example .env && nano .env
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=5001

# Public URL of the deployed frontend. Used for CORS + socket.io origin.
CLIENT_URL=https://spark.proflowenergy.org

# MongoDB. Use MongoDB Atlas (free tier works) or self-hosted mongod.
# Atlas example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/spark
MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/spark

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
JWT_EXPIRES_IN=30d

# Cloudinary — photo + voice-note storage (cloudinary.com).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP for OTP emails. Gmail app-passwords, SendGrid, Mailgun, or
# InterServer's own SMTP all work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
MAIL_FROM="Spark <no-reply@spark.proflowenergy.org>"

# Twilio (SMS OTP — optional, only if phone auth is enabled).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
